---
import BaseLayout from '../../layouts/Layout.astro';

// define static paths for products
export function getStaticPaths() {
    return [
        { params: { slug: 'italy-huge-travertine' } },
        { params: { slug: 'round-line-stone' } },
    ];
}

const products = {
    'round-line-stone': {
        name: 'Round Line Stone',
        description: 'Dekoratívny panel s realistickým vzhľadom kameňa. Moderná štruktúra s jemným 3D efektom.',
        images: ['/product-1.jpeg', '/product-1.jpeg', '/product-1.jpeg'],
        vlastnosti: ['Realistická imitácia kameňa', 'Výrazná 3D štruktúra', 'Ľahký a flexibilný', 'Jednoduchá manipulácia'],
        technicke: ['Materiál: polyuretán (PU)', 'Odolnosť voči vlhkosti a vode', 'Protipožiarna klasifikácia A1', 'Farebná stálosť'],
        vyhody: ['Rýchla a jednoduchá montáž', 'Bez zaťaženia konštrukcie', 'Vhodný aj na väčšie plochy'],
        pouzitie: ['Vhodný do interiéru aj exteriéru', 'Ideálny pre steny a dekoratívne prvky'],
        rozmery: '595 × 2800 mm',
        hrubka: '2 – 8 mm',
        hmotnost: '9 kg/kus',
        skladom: 'skladom',
        farba: { hex: '#d4c5b0', nazov: 'Beige' },
    },
    'italy-huge-travertine': {
        name: 'Italy Huge Travertine',
        description: 'Flexibilný panel s autentickým vzhľadom travertínu. Nadčasový dizajn s priznanou štruktúrou kameňa.',
        images: ['/product-2.jpeg', '/product-2.jpeg', '/product-2.jpeg'],
        vlastnosti: ['Realistická textúra travertínu', 'Jemná pórovitosť a prirodzené žilkovanie', 'Flexibilný – prispôsobí sa povrchu'],
        technicke: ['Protipožiarna trieda A1', 'Vodoodolný', 'UV stabilný – nevybledne', 'Odolnosť voči vlhkosti a vode'],
        vyhody: ['Jednoduchá montáž (lepidlo)', 'Bez potreby zložitých konštrukcií'],
        pouzitie: ['Bezšvový vzhľad veľkoformátových panelov', 'Vhodný na steny, stropy aj nábytok', 'Interiér aj exteriér'],
        rozmery: '1200 × 2900 mm',
        hrubka: '3 – 5 mm',
        hmotnost: '15 kg/kus',
        skladom: 'skladom',
        farba: { hex: '#c8b89a', nazov: 'Beige' },
    },
};

const { slug } = Astro.params;
const product = products[slug as keyof typeof products];
if (!product) return Astro.redirect('/');
---

<BaseLayout title={product.name + ' — Decora Panels'}>
    <div class="product-page">

        <div class="product-left">
            <div class="gallery">
                <img src={product.images[0]} alt={product.name} class="img-main" id="mainImg" />
                {product.images.length > 1 && (
                        <div class="thumbnails">
                            {product.images.map((img, i) => (
                                    <img
                                            src={img}
                                            alt={product.name}
                                            class={`thumb ${i === 0 ? 'active' : ''}`}
                                            data-src={img}
                                    />
                            ))}
                        </div>
                )}
            </div>
            <div class="rozmery-under">
                <div class="rozmer-row">
                    <div class="rozmer-item">
                        <span class="rozmer-label">Formát</span>
                        <span class="rozmer-value">{product.rozmery}</span>
                    </div>
                    <div class="rozmer-item">
                        <span class="rozmer-label">Hrúbka</span>
                        <span class="rozmer-value">{product.hrubka}</span>
                    </div>
                    <div class="rozmer-item">
                        <span class="rozmer-label">Hmotnost</span>
                        <span class="rozmer-value">{product.hmotnost}</span>
                    </div>
                    <div class="rozmer-item farba-item">
                        <span class="rozmer-label">Farba</span>
                        <div class="farba-wrap">
                            <div class="farba-vzorka" style={`background: ${product.farba.hex};`}></div>
                            <span class="farba-label">{product.farba.nazov}</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="product-right">
            <a href="/#ponuka" class="back">← Späť</a>

            <div class="product-header">
                <p class="eyebrow">Dekoračné panely</p>
                <h1>{product.name}</h1>
                <p class="description">{product.description}</p>
            </div>

            <div class="blocks">
                <div class="block-group">
                    <p class="block-title">Vlastnosti</p>
                    <div class="block-table">
                        {product.vlastnosti.map(v => (
                                <div class="table-row">
                                    <span class="table-dot"></span>
                                    <span class="table-value">{v}</span>
                                </div>
                        ))}
                    </div>
                </div>

                <div class="block-group">
                    <p class="block-title">Technické vlastnosti</p>
                    <div class="block-table">
                        {product.technicke.map(v => (
                                <div class="table-row">
                                    <span class="table-dot"></span>
                                    <span class="table-value">{v}</span>
                                </div>
                        ))}
                    </div>
                </div>

                <div class="two-col">
                    <div class="block-group">
                        <p class="block-title">Výhody</p>
                        <div class="block-table">
                            {product.vyhody.map(v => (
                                    <div class="table-row">
                                        <span class="table-dot"></span>
                                        <span class="table-value">{v}</span>
                                    </div>
                            ))}
                        </div>
                    </div>
                    <div class="block-group">
                        <p class="block-title">Použitie</p>
                        <div class="block-table">
                            {product.pouzitie.map(v => (
                                    <div class="table-row">
                                        <span class="table-dot"></span>
                                        <span class="table-value">{v}</span>
                                    </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
    <div class="btn-wrap">
        <p class={`skladom ${product.skladom === 'Skladom' ? 'green' : 'muted'}`}>
            {product.skladom}
        </p>
        <a href="/#kontakt" class="btn">Kontaktujte nás</a>
    </div>
        </div>

    </div>
</BaseLayout>

<style>
    .product-page {
        display: grid;
        grid-template-columns: 1fr 1fr;
        height: 100vh;
        overflow: hidden;
        background: #0f0d0b;
    }

    /* LEFT */
    .product-left {
        display: flex;
        flex-direction: column;
        height: 100vh;
    }

    .gallery {
        flex: 1;
        position: relative;
        min-height: 0;
    }

    .img-main {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: opacity 0.4s ease;
    }

    .thumbnails {
        position: absolute;
        bottom: 16px;
        left: 16px;
        display: flex;
        gap: 8px;
    }

    .thumb {
        width: 56px;
        height: 56px;
        object-fit: cover;
        opacity: 0.5;
        cursor: pointer;
        transition: opacity 0.3s ease;
        border: 0.5px solid transparent;
    }

    .thumb.active,
    .thumb:hover {
        opacity: 1;
        border-color: rgba(245, 239, 232, 0.5);
    }

    .rozmery-under {
        padding: 20px 32px;
        background: #0f0d0b;
        border-top: 0.5px solid rgba(240, 232, 223, 0.07);
    }

    .rozmer-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .rozmer-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .rozmer-label {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(240, 232, 223, 1);
    }

    .rozmer-value {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 300;
        color: rgba(240, 232, 223, 0.7);
        letter-spacing: 0.04em;
    }

    .farba-wrap {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .farba-vzorka {
        width: 20px;
        height: 20px;
        border: 0.5px solid rgba(240, 232, 223, 0.15);
    }

    .farba-label {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        font-weight: 300;
        color: rgba(240, 232, 223, 0.7);
        letter-spacing: 0.06em;
    }

    /* RIGHT */
    .product-right {
        padding: 80px 64px 60px;
        display: flex;
        flex-direction: column;
        gap: 36px;
        height: 100vh;
        overflow: hidden;
    }

    .back {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(245, 239, 232, 0.4);
        text-decoration: none;
        transition: color 0.3s ease;
        align-self: flex-start;
    }

    .back:hover { color: rgba(245, 239, 232, 0.8); }

    .product-header {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .eyebrow {
        font-family: 'Inter', sans-serif;
        font-size: 10px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: rgba(240, 232, 223, 0.35);
    }

    h1 {
        font-family: 'Airy Restoration', Georgia, serif;
        font-size: clamp(32px, 4vw, 52px);
        font-weight: 400;
        color: #f5efe8;
        letter-spacing: 0.04em;
        line-height: 1.1;
    }

    .description {
        font-family: 'DM Serif Display', Georgia, serif;
        font-size: 15px;
        font-style: italic;
        font-weight: 300;
        color: rgba(245, 239, 232, 0.75);
        line-height: 1.7;
        letter-spacing: 0.04em;

    }

    .blocks {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .block-group {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .block-title {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 400;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: rgba(240, 232, 223, 1);
        padding-bottom: 8px;
        border-bottom: 0.5px solid rgba(240, 232, 223, 0.07);
    }

    .block-table {
        display: flex;
        flex-direction: column;
    }

    .table-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 0;
        border-bottom: 0.5px solid rgba(240, 232, 223, 0.05);
    }

    .table-dot {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: rgba(240, 232, 223, 0.3);
        flex-shrink: 0;
    }

    .table-value {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 500;
        color: rgba(240, 232, 223, 0.8);
        letter-spacing: 0.02em;
        line-height: 1.5;
    }

    .btn-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-top: auto;
        padding-top: 16px;
        border-top: 0.5px solid rgba(240, 232, 223, 0.07);
    }

    .skladom {
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        font-weight: 300;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(120, 200, 150, 0.87);
        order: 0;
    }

    .btn {
        display: inline-block;
        border: 0.5px solid rgba(245, 239, 232, 0.35);
        padding: 14px 40px;
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: #f5efe8;
        text-decoration: none;
        align-self: flex-start;
        margin-top: auto;
        transition: background 0.3s ease, border-color 0.3s ease;
    }

    .btn:hover {
        background: rgba(245, 239, 232, 0.06);
        border-color: rgba(245, 239, 232, 0.7);
    }

    @media (max-width: 768px) {
        .product-page {
            grid-template-columns: 1fr;
            height: auto;
            overflow: auto;
        }

        .product-left { height: auto; }
        .gallery { height: 50vh; }

        .product-right {
            height: auto;
            overflow: visible;
            padding: 30px 24px 64px;
        }

        .two-col {
            grid-template-columns: 1fr;
        }

        .rozmer-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }
    }
</style>

<script>
    const thumbs = document.querySelectorAll('.thumb');
    const mainImg = document.getElementById('mainImg') as HTMLImageElement;

    thumbs.forEach(thumb => {
        thumb.addEventListener('click', () => {
            const src = (thumb as HTMLElement).dataset.src;
            if (src && mainImg) {
                mainImg.style.opacity = '0';
                setTimeout(() => {
                    mainImg.src = src;
                    mainImg.style.opacity = '1';
                }, 300);
            }
            thumbs.forEach(t => t.classList.remove('active'));
            thumb.classList.add('active');
        });
    });
</script>