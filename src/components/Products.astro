<section class="products" id="ponuka">
    <div class="product-card reveal">
        <img src="/product-1.jpeg" alt="Italy Huge Travertine" />
        <div class="overlay"></div>
        <div class="product-content">
            <h3>Italy Huge<br>Travertine</h3>
            <a href="/produkt/italy-huge-travertine" class="product-link">Zobraziť</a>
        </div>
    </div>

    <div class="product-card reveal">
        <img src="/product-2.jpeg" alt="Round Line Stone" />
        <div class="overlay"></div>
        <div class="product-content">
            <h3>Round Line<br>Stone</h3>
            <a href="/produkt/round-line-stone" class="product-link">Zobraziť</a>        </div>
    </div>
</section>

<style>
    .products {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px;
        height: 100vh;
        transition: grid-template-columns 1s ease;
    }
    .products:has(.product-card:first-child:hover) {
        grid-template-columns: 1.01fr 0.99fr;
    }

    .products:has(.product-card:last-child:hover) {
        grid-template-columns: 0.99fr 1.01fr;
    }


    .product-card {
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .product-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .product-card:hover img {
        transform: scale(1.03);
    }

    .product-card:hover .overlay {
        opacity: 0.8;
    }

    .overlay {
        position: absolute;
        inset: 0;
        opacity: 1;
        background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 40%, transparent 100%);
        transition: background 5s ease;
    }


    .product-content {
        position: absolute;
        bottom: 40px;
        left: 40px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    h3 {
        font-family: 'Airy Restoration', Georgia, serif;
        font-size: clamp(28px, 3vw, 44px);
        font-weight: 400;
        color: #f5efe8;
        letter-spacing: 0.03em;
        line-height: 1.15;
    }

    .product-link {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 300;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: rgba(245, 239, 232, 0.6);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        position: relative;
        transition: color 0.3s ease;
    }

    .product-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 0.5px;
        background: rgba(245, 239, 232, 0.7);
        transition: width 0.4s ease;
    }

    .product-link:hover {
        color: #f5efe8;
    }

    .product-link:hover::after {
        width: 30%;
    }

    @media (max-width: 768px) {
        .products {
            grid-template-columns: 1fr;
            height: auto;
            display: flex;
            flex-direction: column;
        }

        .product-card img {
            height: 50vh;
        }

        .product-content {
            bottom: 28px;
            left: 24px;
        }
    }
</style>