---
---

<section class="contact" id="kontakt">
    <div class="header reveal">
        <h2>KONTAKT</h2>
        <p>Spojte sa s nami</p>
    </div>

    <div class="contact-inner">
        <div class="form-side reveal">
            <p class="form-title">Napíšte nám</p>
            <p class="form-sub">Odpovieme do 24 hodín.</p>

            <form id="contactForm">
                <div class="row">
                    <input type="text" name="meno" placeholder="Meno" required />
                    <input type="text" name="priezvisko" placeholder="Priezvisko" required />
                </div>
                <input type="email" name="email" placeholder="Email" required />
                <input type="tel" name="telefon" placeholder="Telefónne číslo" />
                <textarea name="sprava" placeholder="Správa" rows="5" required></textarea>
                <button type="submit">Odoslať</button>
            </form>
            <p class="toast" id="toast">Správa bola odoslaná ✓</p>
        </div>

        <div class="info-side reveal">
            <div class="info-group">
                <p class="info-title">Fakturačné údaje</p>
                <div class="info-line"></div>
                <p class="info-text">
                    Alma3 s.r.o.<br>
                    Vajanského 2845/5A<br>
                    IČO: 50 352 342<br>
                    DIČ: 2120 2969 04<br>
                    IČDPH: SK2120 2969 04
                </p>
            </div>

            <div class="info-group">
                <p class="info-title">Kontaktné údaje</p>
                <div class="info-line"></div>
                <p class="info-text">
                    <a href="tel:+421915838764">+421 915 838 764</a><br>
                    <a href="mailto:info@decorapanels.sk">info@decorapanels.sk</a><br>
                </p>
            </div>

            <div class="info-group">
                <p class="info-title">Adresa</p>
                <div class="info-line"></div>
                <p class="info-text">
                    <a href="https://www.google.com/maps/place/Dostojevsk%C3%A9ho,+934+05+Levice,+Slovensko/@48.2109361,18.592839,18z/data=!4m10!1m2!2m1!1sul.+Dostojevsk%C3%A9ho+3848,+934+05+Levice!3m6!1s0x476addb363ce7ee3:0x26cf93fcc07f2b02!8m2!3d48.2101868!4d18.5925056!15sCiZ1bC4gRG9zdG9qZXZza8OpaG8gMzg0OCwgOTM0IDA1IExldmljZZIBBXJvdXRl4AEA!16s%2Fg%2F1tdjvtq1?entry=ttu&g_ep=EgoyMDI2MDMyMy4xIKXMDSoASAFQAw%3D%3D" target="_blank">
                        ul. Dostojevského 3848, 934 05 Levice
                    </a>                   <br>
                    Otváracia doba: po telefonickej dohode
                </p>
            </div>

            <div class="info-group">
                <p class="info-title">Sociálne siete</p>
                <div class="info-line"></div>
                <p class="info-text">
                    <a href="https://www.instagram.com/decora_panels/">Instagram</a>
                </p>
            </div>
        </div>
    </div>
</section>

<style>
    .contact {
        background: #0f0d0b;
        padding: 100px 80px;
    }

    .header {
        text-align: center;
        margin-bottom: 72px;
    }

    h2 {
        font-family: 'Airy Restoration', Georgia, serif;
        font-size: clamp(40px, 6vw, 80px);
        font-weight: 400;
        color: #f0e8df;
        letter-spacing: 0.1em;
        margin-bottom: 12px;
    }

    .header p {
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 300;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(240, 232, 223, 0.8);
    }

    .contact-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: start;
    }

    /* Form */
    .form-title {
        font-family: 'Inter', sans-serif;
        font-size: 18px;
        font-weight: 400;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(240, 232, 223, 0.85);
        margin-bottom: 6px;
        color: #BCA584;
    }

    .form-sub {
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        font-weight: 300;
        color: rgba(240, 232, 223, 0.6);
        margin-bottom: 28px;
    }

    form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    input, textarea {
        width: 100%;
        background: none;
        border: none;
        border-bottom: 0.5px solid rgba(240, 232, 223, 0.15);
        padding: 12px 0;
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 300;
        color: rgb(255, 255, 255);
        outline: none;
        transition: border-color 0.3s ease;
        resize: none;
    }

    input::placeholder, textarea::placeholder {
        color: rgba(240, 232, 223, 0.6);
    }

    input:focus, textarea:focus {
        border-bottom-color: rgba(240, 232, 223, 0.5);
    }

    button {
        align-self: flex-start;
        background: none;
        border: 0.5px solid rgba(240, 232, 223, 0.35);
        padding: 14px 36px;
        font-family: 'Inter', sans-serif;
        font-size: 11px;
        font-weight: 300;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: #f0e8df;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.3s ease, border-color 0.3s ease;
    }

    button:hover {
        background: rgba(240, 232, 223, 0.06);
        border-color: rgba(240, 232, 223, 0.7);
    }

    /* Info */
    .info-side {
        display: flex;
        flex-direction: column;
        gap: 32px;
    }

    .info-group {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .info-title {
        font-family: 'Inter', sans-serif;
        font-size: 16px;
        font-weight: 400;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(240, 232, 223, 0.5);
        color: #BCA584;
    }

    .info-line {
        width: 100%;
        height: 0.5px;
        background: rgba(240, 232, 223, 0.08);
    }

    .info-text {
        font-family: 'Inter', sans-serif;
        font-size: 14px;
        font-weight: 300;
        color: rgba(240, 232, 223, 0.4);
        line-height: 1.9;
    }

    .info-text a {
        color: rgba(240, 232, 223, 0.55);
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .info-text a:hover {
        color: #f0e8df;
    }

    .toast {
        opacity: 0;
        pointer-events: none;
        font-family: 'Inter', sans-serif;
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(120, 200, 150, 0.8);
        transition: opacity 0.4s ease;
    }

    .toast.visible {
        opacity: 1;
    }

    @media (max-width: 768px) {
        .contact {
            padding: 80px 24px;
        }

        .contact-inner {
            grid-template-columns: 1fr;
            gap: 56px;
        }

        .row {
            grid-template-columns: 1fr;
        }
    }
</style>

<script>
    const form = document.getElementById('contactForm');
    const toast = document.getElementById('toast');

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const data = new FormData(form as HTMLFormElement); // data gonna be sent to contact.php as POST request in  || name => value format (FormData object)

        const res = await fetch('/contact.php', {
            method: 'POST',
            body: data,
        });

        if (res.ok) {
            toast?.classList.add('visible');
            (form as HTMLFormElement).reset();
            setTimeout(() => toast?.classList.remove('visible'), 4000);
        }
    });
</script>