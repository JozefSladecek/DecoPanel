<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="UTF-8">
    <title>Decora Panels</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;700&display=swap" rel="stylesheet">
</head>
<body>
<section class="hero">
    <div class="hero-content">
        <p class="subtitle">Veľkoformatové Dekoračné Panely</p>
        <h1>DECORA PANELS</h1>
        <div class="buttons">
            <a href="#kontakt" class="btn">Kontakt</a>
            <a href="#ponuka" class="btn">Ponuka</a>
        </div>
    </div>
    <div class="scroll-indicator">
        <span>SCROLL</span>
        <div class="line">
            <div class="line-inner"></div>
        </div>
    </div>
</section>
</body>
</html>

<style>
    .hero {
        position: relative;
        width: 100%;
        height: 100svh;
        background-image: url('/Hero.avif');
        background-size: cover;
        background-position: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    .hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.4);

        z-index: 0;
    }

    .hero-content {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        z-index: 1;

    }

    .subtitle {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(20px, 2.5vw, 28px);
        font-style: italic;
        font-weight: 300;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: 0.06em;
        margin-bottom: 22px;
    }

    h1 {
        font-family: 'Airy Restoration', Georgia, serif;
        font-size: clamp(80px, 9vw, 128px);
        font-weight: 400;
        color: #f5efe8;
        letter-spacing: 0.05em;
        line-height: 1;
    }

    .buttons {
        display: flex;
        gap: 44px;
        margin-top: 8px;
    }

    .btn {
        border: 0.5px solid rgba(245, 239, 232, 0.5);
        padding: 14px 36px;
        font-family: 'Inter', sans-serif;
        font-size: 13px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #f5efe8;
        text-decoration: none;
        transition: background 0.3s ease, border-color 0.3s ease;
    }

    .btn:hover {
        background: rgba(245, 239, 232, 0.08);
        border-color: rgba(245, 239, 232, 0.8);
    }

    .scroll-indicator {
        z-index: 1;
        position: absolute;
        bottom: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .scroll-indicator span {
        font-size: 10px;
        letter-spacing: 0.22em;
        color: rgba(245, 239, 232, 0.75);
        font-family: 'Inter', sans-serif;
    }

    .line {
        width: 1px;
        height: 40px;
        background: rgba(245, 239, 232, 0.15);
        overflow: hidden;
    }

    .line-inner {
        width: 100%;
        height: 100%;
        background: rgba(245, 239, 232, 0.8);
        transform: translateY(-100%);
        animation: scrollLine 2s ease-in-out infinite;
    }

    @keyframes scrollLine {
        0% { transform: translateY(-100%); }
        50% { transform: translateY(0%); }
        100% { transform: translateY(100%); }
    }
</style>